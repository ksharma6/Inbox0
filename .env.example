# LLM Configuration
# Supports any model available through OpenRouter or compatible with the OpenAI SDK
OPENROUTER_API_KEY=your-api-key-here
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Gmail OAuth
# Absolute path to the tokens folder containing credentials.json (must end with /)
TOKENS_PATH=/absolute/path/to/inbox_zero/tokens/
